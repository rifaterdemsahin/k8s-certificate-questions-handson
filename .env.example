# .env.example - Local environment variables template
# NOTE: Real secrets are never committed to git. Load them at runtime via Azure Key Vault.
#       Reuse the EXISTING vault below — do not create a new one.

# --- AZURE KEY VAULT CONFIGURATION (EXISTING SHARED VAULT) ---
AZURE_KEYVAULT_NAME="dp-kv-deliverypilot"
AZURE_RESOURCE_GROUP="deliverypilot-rg"
AZURE_SUBSCRIPTION_ID="b85b029d-9f7c-4c5a-8939-819480780c5d"
AZURE_TENANT_ID="infodeliverypilot.onmicrosoft.com"
AZURE_CLIENT_ID="your-service-principal-client-id"
AZURE_CLIENT_SECRET="your-service-principal-client-secret"

# --- KUBERNETES HANDS-ON (minikube, local) ---
# Profile name used by the draining demo in 5_Symbols/
MINIKUBE_PROFILE="k8s-cert-qa"
MINIKUBE_NODES="2"

# --- FLY.IO (CONTAINER-BASED DEPLOYMENTS) ---
# Used to deploy the sample workload that survives a node drain.
# Store the real token in Key Vault; inject via `fly secrets set` at deploy time.
FLY_API_TOKEN="your-fly-api-token"
FLY_APP_NAME="k8s-cert-qa-handson"

# --- AXIOM (SERVER-SIDE LOGS, OPTIONAL) ---
AXIOM_TOKEN="xaat-your-axiom-api-token"
AXIOM_DATASET="k8s-cert-qa-dev"
# Optional: AXIOM_ORG_ID for org-scoped tokens
